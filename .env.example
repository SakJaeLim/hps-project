# ─── RDB (NEON PostgreSQL) ───
NEON_DATABASE_URL=              # postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── 지식그래프 (Neo4j) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── RAG (ChromaDB) ───
CHROMA_PERSIST_DIR=             # ChromaDB 영속화 경로 (비어있으면 인메모리)
CHROMA_COLLECTION=hps_docs     # 기본 컬렉션명

# ─── 앱 설정 ───
DATA_PROVIDER=simulated        # simulated | snct_live
ENGINE=rl                      # rl(원우 모델·기본) | greedy(기준선) | cp(향후) — ADR-0001
SNCT_BASE_DIR=                 # 프로젝트 루트 (비어있으면 자동 탐색)

# ─── SLM / HuggingFace ───
LLM_API_KEY=
HF_TOKEN=                     # HuggingFace 토큰 (모델 다운로드/업로드)
HF_SPACE_URL=                  # HF Spaces URL (원격 추론)
